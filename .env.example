# ══════════════════════════════════════════════════════════════════════════════
#  ShortFactory — .env.example
#  Copie ce fichier en .env et remplis tes valeurs (ne commite JAMAIS .env)
# ══════════════════════════════════════════════════════════════════════════════
#
#  LOCAL : npm install && npm start → ouvre http://localhost:3000
#  (OAuth TikTok nécessite HTTPS public — utilise Render pour connecter TikTok)
#
# PORT=3000

# ── TikTok Login Kit ──────────────────────────────────────────────────────────
# Récupère ces valeurs sur https://developers.tiktok.com → ton app → App Info
TIKTOK_CLIENT_KEY=aw7o1osbhtac2nzo
TIKTOK_CLIENT_SECRET=ykc2r2xozFOwmlfAQ01L4pIR0tnSeU9e

# URI de redirection APRÈS connexion TikTok (doit matcher exactement le portail)
# ⚠️  TikTok EXIGE une URL HTTPS publique — jamais http://localhost
TIKTOK_REDIRECT_URI=https://shortfactory.onrender.com/auth/tiktok/callback

# Niveau de confidentialité par défaut (app non auditée → SELF_ONLY obligatoire)
# Valeurs possibles : SELF_ONLY | MUTUAL_FOLLOW_FRIENDS | PUBLIC_TO_EVERYONE
TIKTOK_PRIVACY_LEVEL=SELF_ONLY

# 1 = préférer SELF_ONLY automatiquement pour les apps non auditées (recommandé)
TIKTOK_UNAUDITED_DEFAULT=1

# 1 = interface « télécharge MP4 → import TikTok » seule (masque OAuth / Publier API), même si les clés ci-dessus sont remplies
SHORTFACTORY_MANUAL_TIKTOK=1

# ── URLs publiques (OBLIGATOIRE pour Render / déploiement cloud) ──────────────
# Remplace par l'URL réelle de ton service Render
PUBLIC_BASE_URL=https://shortfactory.onrender.com

# Active si le serveur est derrière un reverse proxy (Render, Railway, etc.)
TRUST_PROXY=1

# ── Publication auto après génération (style CapCut) ─────────────────────────
# 1 = publie automatiquement chaque short dès qu'il est encodé
CAPCUT_PUBLISH_AFTER_GENERATE=1

# ── Génération vidéo ──────────────────────────────────────────────────────────
GEN_BUDGET_MS=600000        # budget total génération en ms (10 min)
GEN_MAX_SHORTS=100          # max shorts par vidéo
SHORT_SEGMENT_SEC=60        # durée d'un short en secondes
SHORTS_FRAME_FIT=pad        # pad = tout cadrer (bandes noires) | crop = zoom centré
ENCODE_PARALLEL=2           # encodages simultanés (1–4)
ENCODE_PRESET=ultrafast     # ultrafast/veryfast/fast/medium (ultrafast = ~30s/short)
ENCODE_CRF=26               # qualité (18=top qualité, 28=léger)
SUBTITLE_BURN=0             # 1 = mots décoratifs style CapCut incrustés | 0 = sans texte
